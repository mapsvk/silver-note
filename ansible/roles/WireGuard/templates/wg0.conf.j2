[Interface]
Address = {{ wg_Address }}
ListenPort = {{ wg_ListenPort }}
PrivateKey = {{ wg_private_key_output }}

PostUp = iptables -A FORWARD -i %i -o {{ ansible_default_ipv4.interface }} -j ACCEPT; iptables -A FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT; iptables -A FORWARD -i %i -o %i -j REJECT --reject-with icmp-port-unreachable; iptables -t nat -A POSTROUTING -o {{ ansible_default_ipv4.interface }} -j MASQUERADE
PostDown = iptables -D FORWARD -i %i -o {{ ansible_default_ipv4.interface }} -j ACCEPT; iptables -D FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT; iptables -D FORWARD -i %i -o %i -j REJECT --reject-with icmp-port-unreachable; iptables -t nat -D POSTROUTING -o {{ ansible_default_ipv4.interface }} -j MASQUERADE

